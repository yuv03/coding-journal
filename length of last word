class Solution {
public:
    int lengthOfLastWord(string s) {
        int i = s.size();

        while(i>0){
            i--;
            if(s[i] != ' ') break;
        }
        int count =0;
        int j =i;
        while(j>=0 && s[j]!=' '){
            count++;
            j--;
        }
        return count;
    }
};
