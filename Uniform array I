class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        // 3,6,8   ----1 odd true
        // 3,5,8   ----1 even true

        int odd =0;
        int even =0;

        for(int i=0; i<nums1.size(); i++){
            if(nums1[i]%2==0) even++;
            else odd++;
        }
        if(even || odd) return true;
        return false;
        
    }
};
